// CEDAFAM — Sistema de Gestión de Consultas Psicológicas
// PostgreSQL + Prisma. Sessions are JWT-based (NextAuth Credentials), so no
// adapter tables are needed.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────────────────── Enums

enum Role {
  ADMIN // Jefe Principal
  COORDINATOR // Coordinación de Atención
  ACCOUNTANT // Contadora (solo lectura)
  PSYCHOLOGIST // Psicólogos / Neuropsicóloga / Psiquiatra
}

// Puesto que ocupa una persona dentro del centro, aparte de su rol de acceso.
// Cada puesto abre su propio módulo de trabajo en la barra lateral; el Jefe
// Principal los ve todos. Un usuario puede no tener puesto (null).
enum Position {
  PRIVATE_CARE_SERVICES // Coordinación Servicios de Atención Privada
  INNOVATION_RESEARCH // Coordinación Innovación e Investigación
  PROFESSIONAL_DEVELOPMENT // Coordinación Desarrollo Profesional
  COMMUNITY_OUTREACH // Coordinación Extensión a la Comunidad
  HUMAN_CAPITAL // Coordinación Capital Humano
  BIRTHDAYS // Cumpleaños
}

enum Speciality {
  CLINICAL
  EDUCATIONAL
  FAMILY_THERAPY
  NEUROPSYCHOLOGY
  PSYCHIATRY
}

enum WorkType {
  FULL_TIME
  PART_TIME
  INTERN // Pasante (1 año)
  FELLOW // Becario (2 años)
}

enum ServiceArea {
  PSYCHOLOGY
  PSYCHIATRY
  PSYCHOLOGICAL_EVALUATION
  NEUROPSYCHOLOGICAL
}

enum ReferenceType {
  UM_STUDENT
  COAE
  UM_EMPLOYEE
  HOSPITAL_EMPLOYEE
  DUPS
  NONE
}

enum TimeSlot {
  MORNING // 9:00 - 11:00
  AFTERNOON // 14:30 - 17:30
}

enum ServiceType {
  THERAPY
  EVALUATION
  PSYCHIATRY
}

enum PatientType {
  PARTICULAR
  UM_EMPLOYEE // Empleado UM
  HLC_EMPLOYEE // Empleado HLC
  UM_STUDENT // Alumno UM
  SIERE
}

enum TherapyStatus {
  ACTIVE
  THERAPEUTIC_DISCHARGE
  VOLUNTARY_DISCHARGE
  NEVER_CAME
  REFERRED
  CANCELLED
}

enum EvaluationStatus {
  WAITLIST
  TEST_APPLICATION
  REPORT_PREPARATION
  EVALUATION_COMPLETED
  REFERRAL
  CANCELLED
}

enum AppointmentServiceType {
  THERAPY
  EXPLORATION_SESSION
  EVALUATION
}

enum AppointmentStatus {
  PENDING // solicitud de cita, espera aprobación de la Contadora
  SCHEDULED
  ATTENDED
  NO_SHOW
  CANCELLED
  REJECTED // solicitud rechazada por la Contadora (con motivo)
  RESCHEDULED // el psicólogo cambió la cita a otra fecha/hora
}

// Espacios físicos donde se toma la terapia. Un espacio no puede estar
// reservado por dos citas que se solapen en horario. Son 7 consultorios; la
// Contadora asigna cada cita agendada a uno desde el tablero de Consultorios.
enum Room {
  GESELL // Cámara Gesell
  LUDOTECA // Ludoteca
  OFFICE_ANTONIO // Oficina de Antonio
  CONSULTORIO_1 // Consultorio 1 (Neuropsicología)
  CONSULTORIO_2 // Consultorio 2
  CONSULTORIO_EVALUACION // Consultorio de Evaluación
  CONSULTORIO_3 // Consultorio 3
}

// Estado de autorización del consultorio por parte de coordinación.
enum RoomBookingStatus {
  PENDING // solicitada por un psicólogo, espera visto bueno
  APPROVED
  REJECTED
}

enum DiscountLevel {
  LEVEL_1 // $100
  LEVEL_2 // $280
  LEVEL_3 // $370
  LEVEL_4 // $490
}

enum NotificationType {
  NEW_FORM_SUBMITTED
  PATIENT_ASSIGNED
  WEEKLY_REPORT_DUE
  URGENT
  ROOM_AUTH_REQUEST // psicólogo pide un consultorio, coordinación debe autorizar
  ROOM_AUTH_RESULT // resultado de la autorización, dirigido al psicólogo
  APPOINTMENT_REQUEST // nueva solicitud de cita, dirigida a la Contadora
  APPOINTMENT_REQUEST_RESULT // resultado de la solicitud (aceptada/rechazada), al psicólogo
  APPOINTMENT_REMINDER // cita con paciente en ~30 min, al psicólogo asignado
  EVENT_REMINDER // evento interno (jefatura/coordinación) en ~30 min, a todos
  ANNOUNCEMENT // aviso manual de jefatura/coordinación/contabilidad a todos los usuarios
  LEAVE_REQUEST // solicitud de permiso, dirigida a Coordinación Desarrollo Profesional
  LEAVE_REQUEST_RESULT // resultado del permiso (aceptado/rechazado), al psicólogo
  EVENT_INVITATION // invitación a un evento de coordinación
  PATIENT_MATCH_REVIEW // solicitud del form público hizo match con un expediente existente, dirigida a Coordinación
}

enum LeaveStatus {
  PENDING // esperando revisión de Coordinación Desarrollo Profesional
  APPROVED
  REJECTED
}

// Programa bajo el que colabora quien pide el permiso (casilla del formato).
enum LeaveProgram {
  POSTGRADUATE // Posgrado
  SOCIAL_SERVICE // Servicio Social
  INTERNSHIP // Practicante
  VOLUNTEER // Voluntariado
}

// El permiso se pide por horas de un día o por días completos.
enum LeaveUnit {
  HOURS
  DAYS
}

// A quiénes aplica un evento del calendario.
enum EventScope {
  ALL // a todos los psicólogos
  SELECTED // solo a los psicólogos invitados (ver CalendarEventAttendee)
}

// Origen del evento: qué módulo lo creó. Define cómo se pinta en el calendario
// y desde dónde se administra.
enum EventKind {
  GENERAL // evento interno clásico (junta, día festivo)
  COMMUNITY // Coordinación Extensión a la Comunidad
  HUMAN_CAPITAL // Coordinación Capital Humano
  BIRTHDAY_PARTY // festejo creado por la coordinación de Cumpleaños
  LEAVE // permiso aprobado a un psicólogo
  CASE_STUDY // estudio de caso — bloquea a todos, expuesto por un psicólogo
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
}

// Resultado de la revisión de un posible expediente existente (ver
// PatientIntakeMatch): Coordinación decide si los datos entrantes se aplican
// al expediente encontrado o si es una persona distinta y se crea uno nuevo.
enum PatientIntakeMatchStatus {
  PENDING
  APPLIED
  CREATED_NEW
}

// Resultado de la revisión de un posible duplicado entre dos expedientes ya
// existentes (ver PatientDuplicateCandidate): Coordinación decide si de
// verdad son la misma persona (se fusionan) o si son personas distintas.
enum PatientDuplicateCandidateStatus {
  PENDING
  MERGED
  NOT_DUPLICATE
}

// Resultado de la revisión de un folio de evaluación histórico sin paciente
// ligado (ver EvaluationFolio.patientId) contra un candidato sugerido por
// número de expediente (ver EvaluationFolioMatch): a diferencia de
// PatientDuplicateCandidate aquí no hay fusión de dos pacientes, solo ligar
// el folio al expediente encontrado o descartar la sugerencia.
enum EvaluationFolioMatchStatus {
  PENDING
  LINKED
  NOT_MATCH
}

// ─────────────────────────────────────────────────────────── Models

model User {
  id        String    @id @default(uuid())
  email     String    @unique
  password  String
  name      String
  role      Role
  // Puesto que ocupa (ej. Coordinación Desarrollo Profesional). Abre el módulo
  // correspondiente en la barra lateral. Null para quien no encabeza ninguno.
  position  Position?
  // Fecha de cumpleaños, capturada por la coordinación de Cumpleaños. Se
  // muestra cada año en el calendario y no bloquea agenda.
  birthDate DateTime?
  isActive  Boolean   @default(true)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  psychologist                   Psychologist?
  notifications                  Notification[]
  auditLogs                      AuditLog[]
  statusChanges                  PatientStatus[]             @relation("StatusChangedBy")
  assignmentsMade                PatientAssignment[]         @relation("AssignedBy")
  siereRequested                 SiereApplication[]          @relation("SiereRequestedBy")
  siereApproved                  SiereApplication[]          @relation("SiereApprovedBy")
  calendarEvents                 CalendarEvent[]             @relation("EventCreatedBy")
  roomAuthorizations             Appointment[]               @relation("RoomAuthorizedBy")
  leaveReviews                   LeaveRequest[]              @relation("LeaveReviewedBy")
  intakeMatchesResolved          PatientIntakeMatch[]        @relation("PatientIntakeMatchResolvedBy")
  evaluationFolios               EvaluationFolio[]           @relation("EvaluationFolioEvaluator")
  duplicateCandidatesResolved    PatientDuplicateCandidate[] @relation("PatientDuplicateCandidateResolvedBy")
  evaluationFolioMatchesResolved EvaluationFolioMatch[]      @relation("EvaluationFolioMatchResolvedBy")

  @@index([email])
  @@index([position])
  @@map("users")
}

model Psychologist {
  id            String     @id @default(uuid())
  userId        String     @unique
  speciality    Speciality
  licenseNumber String?
  workType      WorkType
  startDate     DateTime   @default(now())
  endDate       DateTime? // rotativos: becarios 2 años, pasantes 1 año
  isActive      Boolean    @default(true)
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  user                  User                       @relation(fields: [userId], references: [id], onDelete: Cascade)
  assignments           PatientAssignment[]
  appointments          Appointment[]
  coTherapyAppointments Appointment[]              @relation("CoTherapist")
  availability          PsychologistAvailability[]
  weeklyReports         WeeklyReport[]
  siere                 SiereApplication[]
  eventInvitations      CalendarEventAttendee[]
  leaveRequests         LeaveRequest[]

  @@index([speciality])
  @@index([isActive])
  @@map("psychologists")
}

model Patient {
  id                 String        @id @default(uuid())
  fullName           String
  fileNumber         String? // expediente hospital, capturado a mano (vive en otro sistema)
  cedafamFolio       String?       @map("cedafamfolio") // folio CEDAFAM, capturado a mano (vive en otro sistema)
  age                Int
  dateOfBirth        DateTime?
  curp               String?
  phoneNumber        String
  address            String?
  postalCode         String?
  email              String?
  serviceArea        ServiceArea
  referenceType      ReferenceType @default(NONE)
  patientType        PatientType? // tipo de px, actualizado en el reporte semanal
  consultationReason String
  preferredTimeSlot  TimeSlot
  isHistorical       Boolean       @default(false)
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt

  statuses                        PatientStatus[]
  assignments                     PatientAssignment[]
  appointments                    Appointment[]
  siere                           SiereApplication[]
  reportUpdates                   WeeklyReportPatientUpdate[]
  intakeMatches                   PatientIntakeMatch[]
  evaluationFolios                EvaluationFolio[]
  duplicateCandidatesAsA          PatientDuplicateCandidate[] @relation("PatientDuplicateCandidateA")
  duplicateCandidatesAsB          PatientDuplicateCandidate[] @relation("PatientDuplicateCandidateB")
  evaluationFolioMatchCandidacies EvaluationFolioMatch[]

  @@index([serviceArea])
  @@index([fullName])
  @@index([createdAt])
  @@map("patients")
}

// Append-only history of status changes.
model PatientStatus {
  id               String            @id @default(uuid())
  patientId        String
  serviceType      ServiceType
  therapyStatus    TherapyStatus?
  evaluationStatus EvaluationStatus?
  changedById      String
  changedAt        DateTime          @default(now())
  notes            String?

  patient   Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)
  changedBy User    @relation("StatusChangedBy", fields: [changedById], references: [id])

  @@index([patientId])
  @@index([changedAt])
  @@map("patient_statuses")
}

// Cuando el formulario público de solicitud hace match (nombre + CURP/fecha de
// nacimiento/teléfono) con un Patient existente, no se crea un Patient
// duplicado: se guarda aquí en espera de que Coordinación revise y decida.
// `submittedData` replica la forma de publicPatientCreateSchema (lib/validators.ts).
model PatientIntakeMatch {
  id               String                   @id @default(uuid())
  submittedData    Json
  matchedPatientId String
  // Campo que produjo el match: "curp" | "dateOfBirth" | "phoneNumber".
  matchedByField   String
  status           PatientIntakeMatchStatus @default(PENDING)
  resolvedById     String?
  resolvedAt       DateTime?
  createdAt        DateTime                 @default(now())

  matchedPatient Patient @relation(fields: [matchedPatientId], references: [id], onDelete: Cascade)
  resolvedBy     User?   @relation("PatientIntakeMatchResolvedBy", fields: [resolvedById], references: [id])

  @@index([status])
  @@index([matchedPatientId])
  @@map("patient_intake_matches")
}

// Posible duplicado detectado entre dos expedientes YA existentes (a
// diferencia de PatientIntakeMatch, que solo detecta al llegar una solicitud
// nueva del formulario público). Lo llena scripts/find-duplicate-patients.ts
// al comparar teléfono + nombre similar (ver lib/patient-duplicates.ts);
// Coordinación decide si se fusionan o son personas distintas.
//
// `patientAId`/`patientBId` usan onDelete: SetNull (como EvaluationFolio.
// patientId) para que la fila sobreviva como historial aunque uno de los dos
// expedientes desaparezca al fusionarse; `patientAName`/`patientBName` son la
// copia en texto que sostiene la fila legible en ese caso. `keptPatientId` no
// es relación de Prisma —es solo informativo para la cola— porque el
// expediente que sobrevive normalmente sigue existiendo de todas formas.
model PatientDuplicateCandidate {
  id             String                          @id @default(uuid())
  patientAId     String?
  patientBId     String?
  patientAName   String
  patientBName   String
  // Campo que produjo el match: hoy siempre "phoneNumber" (mismo teléfono +
  // nombre similar); se deja como texto libre por si se agregan más criterios.
  matchedByField String
  status         PatientDuplicateCandidateStatus @default(PENDING)
  keptPatientId  String?
  resolvedById   String?
  resolvedAt     DateTime?
  createdAt      DateTime                        @default(now())

  patientA   Patient? @relation("PatientDuplicateCandidateA", fields: [patientAId], references: [id], onDelete: SetNull)
  patientB   Patient? @relation("PatientDuplicateCandidateB", fields: [patientBId], references: [id], onDelete: SetNull)
  resolvedBy User?    @relation("PatientDuplicateCandidateResolvedBy", fields: [resolvedById], references: [id])

  @@index([status])
  @@index([patientAId])
  @@index([patientBId])
  @@map("patient_duplicate_candidates")
}

// Folio de evaluación. Lo abre el evaluador desde el expediente cuando entrega
// el diagnóstico; la Contadora lo consulta desde el módulo de Evaluaciones y le
// agrega el link del informe.
//
// `folio` es el consecutivo que el centro ya llevaba en papel (ver
// FIRST_EVALUATION_FOLIO en lib/evaluations.ts), no el id: se dicta por
// teléfono y se escribe en el expediente físico.
//
// El modelo carga con dos formas distintas, y por eso casi todo es opcional:
//
//   - Folios nuevos (206 en adelante): cuelgan de un Patient y un User reales,
//     llevan diagnóstico y el rango de fechas capturado con calendario.
//   - Folios históricos (100–205, importados del Excel del centro): son un
//     registro en papel. Muchos de sus pacientes y evaluadores no existen como
//     registros del sistema, no traen diagnóstico, y la fecha viene en texto
//     libre y en formatos irreconciliables ("06 de mayo a 23 de mayo", "5, 6, 9
//     y 12 de febrero de 2026"). Se guardan tal cual en vez de inventarles una
//     interpretación, y se completan a mano desde el módulo.
//
// `patientName`, `fileNumber` y `evaluatorName` son la copia en texto y son
// SIEMPRE la fuente de lo que se muestra: los folios nuevos también la llenan,
// para que la lista se pinte igual sin importar el origen.
model EvaluationFolio {
  id           String  @id @default(uuid())
  folio        Int     @unique
  // Marca los folios importados del registro en papel. Decide qué se le pide
  // al editar y cómo se muestra la fecha.
  isHistorical Boolean @default(false)

  // Copia en texto. Es lo que se muestra, exista o no el registro ligado.
  patientName   String
  fileNumber    String?
  evaluatorName String

  // Registros del sistema, cuando existen. Un histórico puede no tener
  // ninguno: su paciente o su evaluador ya no están dados de alta.
  patientId   String?
  evaluatorId String?

  // Diagnóstico tal como aparece en el DSM-5, capturado literal. Obligatorio
  // al abrir un folio nuevo; vacío en los históricos hasta que alguien lo
  // complete.
  diagnosis String?

  // Rango de la evaluación: de la primera entrevista a la entrega de
  // resultados. Lo llenan los folios nuevos.
  firstInterviewAt   DateTime?
  resultsDeliveryAt  DateTime?
  // La fecha del registro en papel, literal. Solo en los históricos, y solo
  // mientras nadie capture el rango de arriba.
  evaluationDateText String?

  // Link al informe, que agrega la Contadora al revisar el folio.
  reportLink String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  patient   Patient?              @relation(fields: [patientId], references: [id], onDelete: SetNull)
  evaluator User?                 @relation("EvaluationFolioEvaluator", fields: [evaluatorId], references: [id], onDelete: SetNull)
  match     EvaluationFolioMatch?

  // `patientId` NO es único aquí: un paciente puede arrastrar folios
  // históricos y aun así recibir uno nuevo si se reevalúa. Lo que sigue siendo
  // único —un folio nuevo por paciente— lo garantiza un índice parcial creado
  // en SQL, que Prisma no sabe expresar (ver add-evaluaciones-historicos.sql).
  @@index([patientId])
  @@index([evaluatorId])
  @@index([firstInterviewAt])
  @@map("evaluation_folios")
}

// Sugerencia de a qué paciente podría pertenecer un folio histórico sin
// expediente ligado (EvaluationFolio.patientId nulo), por coincidir su
// número de expediente de hospital (ver findEvaluationFolioMatches). Cola de
// revisión análoga a PatientIntakeMatch/PatientDuplicateCandidate, pero
// folio↔paciente: aquí no hay fusión, solo ligar el folio o descartar la
// sugerencia.
model EvaluationFolioMatch {
  id                   String                     @id @default(uuid())
  evaluationFolioId    String                     @unique
  candidatePatientId   String?
  candidatePatientName String
  matchedByField       String // hoy siempre "fileNumber"
  status               EvaluationFolioMatchStatus @default(PENDING)
  resolvedById         String?
  resolvedAt           DateTime?
  createdAt            DateTime                   @default(now())

  evaluationFolio  EvaluationFolio @relation(fields: [evaluationFolioId], references: [id], onDelete: Cascade)
  candidatePatient Patient?        @relation(fields: [candidatePatientId], references: [id], onDelete: SetNull)
  resolvedBy       User?           @relation("EvaluationFolioMatchResolvedBy", fields: [resolvedById], references: [id])

  @@index([status])
  @@index([candidatePatientId])
  @@map("evaluation_folio_matches")
}

model PatientAssignment {
  id                   String   @id @default(uuid())
  patientId            String
  psychologistId       String
  assignedById         String
  assignedAt           DateTime @default(now())
  isExploratorySession Boolean  @default(false)
  isActive             Boolean  @default(true)

  patient      Patient      @relation(fields: [patientId], references: [id], onDelete: Cascade)
  psychologist Psychologist @relation(fields: [psychologistId], references: [id])
  assignedBy   User         @relation("AssignedBy", fields: [assignedById], references: [id])

  @@index([patientId])
  @@index([psychologistId])
  @@index([isActive])
  @@map("patient_assignments")
}

model Appointment {
  id                 String                 @id @default(uuid())
  patientId          String
  psychologistId     String
  // Segundo psicólogo en coterapia (opcional). La cita aparece también en su
  // calendario personal y su horario se valida igual que el del principal.
  coTherapistId      String?
  scheduledAt        DateTime
  duration           Int // minutos
  serviceType        AppointmentServiceType
  status             AppointmentStatus      @default(SCHEDULED)
  // Consultorio reservado (opcional). Requiere autorización de coordinación
  // cuando lo solicita un psicólogo.
  room               Room?
  roomStatus         RoomBookingStatus?
  roomAuthorizedById String?
  roomAuthorizedAt   DateTime?
  // Motivo que deja la Contadora al rechazar una solicitud de cita. Se muestra
  // al psicólogo para que proponga una nueva fecha y reenvíe la solicitud.
  rejectionReason    String?
  notes              String?
  createdAt          DateTime               @default(now())
  updatedAt          DateTime               @updatedAt

  patient          Patient       @relation(fields: [patientId], references: [id], onDelete: Cascade)
  psychologist     Psychologist  @relation(fields: [psychologistId], references: [id])
  coTherapist      Psychologist? @relation("CoTherapist", fields: [coTherapistId], references: [id])
  roomAuthorizedBy User?         @relation("RoomAuthorizedBy", fields: [roomAuthorizedById], references: [id])

  @@index([patientId])
  @@index([psychologistId])
  @@index([coTherapistId])
  @@index([scheduledAt])
  @@index([room, scheduledAt])
  @@map("appointments")
}

// Eventos internos (juntas, días festivos, capacitaciones, eventos de las
// coordinaciones, permisos aprobados…). Los crea jefatura/coordinación o el
// titular de un puesto.
//
// `scope` decide a quién aplican: ALL a todos los psicólogos, SELECTED solo a
// los invitados listados en `attendees`. `blocksAgenda` decide si además
// impiden agendar citas que se solapen con su horario — un festejo informativo
// puede ser visible sin cerrar la agenda de nadie.
model CalendarEvent {
  id           String     @id @default(uuid())
  title        String
  description  String?
  location     String?
  startAt      DateTime
  endAt        DateTime
  // Snapshot de la coordinación del creador al momento de crear el evento.
  // Permite mostrar "Coordinación de …" aunque después cambie la asignación.
  coordination String?
  scope        EventScope @default(ALL)
  kind         EventKind  @default(GENERAL)
  blocksAgenda Boolean    @default(true)
  createdById  String
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  createdBy        User                    @relation("EventCreatedBy", fields: [createdById], references: [id])
  attendees        CalendarEventAttendee[]
  // Presente solo en los eventos de tipo LEAVE: el permiso que los originó.
  leaveRequest     LeaveRequest?           @relation("LeaveBlockEvent")
  // Presente solo en el evento informativo (no bloqueante) que ve quien
  // aprobó el permiso, cuando no es la misma persona que lo solicitó.
  leaveReviewerFor LeaveRequest?           @relation("LeaveReviewerEvent")

  @@index([startAt])
  @@index([kind])
  @@map("calendar_events")
}

// Solicitud de permiso de un psicólogo, dirigida a Coordinación Desarrollo
// Profesional. Reproduce el formato en papel del centro.
//
// Al aprobarse se crea un CalendarEvent de tipo LEAVE que bloquea la agenda de
// esa persona en el rango solicitado; `calendarEventId` apunta a ese bloqueo
// para poder retirarlo si la decisión se revierte. Si quien revisa también es
// psicólogo (y no es la misma persona), se crea además un segundo evento —
// informativo, no bloquea agenda— para que le quede visible en su propio
// calendario lo que autorizó; `reviewerCalendarEventId` apunta a ese.
model LeaveRequest {
  id                      String       @id @default(uuid())
  psychologistId          String
  requestedAt             DateTime     @default(now())
  // Área a la que pertenece, precargada de su especialidad.
  area                    Speciality
  program                 LeaveProgram
  unit                    LeaveUnit
  quantity                Int
  // Día de la ausencia. Con unit = DAYS puede abarcar un rango; con HOURS
  // ambas fechas son el mismo día y el rango real lo dan startTime/endTime.
  startDate               DateTime
  endDate                 DateTime
  startTime               String? // "HH:mm", solo cuando unit = HOURS
  endTime                 String?
  reason                  String
  status                  LeaveStatus  @default(PENDING)
  reviewedById            String?
  reviewedAt              DateTime?
  reviewNote              String? // motivo, obligatorio al rechazar
  calendarEventId         String?      @unique
  reviewerCalendarEventId String?      @unique
  createdAt               DateTime     @default(now())
  updatedAt               DateTime     @updatedAt

  psychologist          Psychologist   @relation(fields: [psychologistId], references: [id], onDelete: Cascade)
  reviewedBy            User?          @relation("LeaveReviewedBy", fields: [reviewedById], references: [id])
  calendarEvent         CalendarEvent? @relation("LeaveBlockEvent", fields: [calendarEventId], references: [id], onDelete: SetNull)
  reviewerCalendarEvent CalendarEvent? @relation("LeaveReviewerEvent", fields: [reviewerCalendarEventId], references: [id], onDelete: SetNull)

  @@index([psychologistId])
  @@index([status])
  @@index([startDate])
  @@map("leave_requests")
}

// Psicólogos invitados a un evento de alcance SELECTED. Son los únicos a
// quienes se les notifica y a quienes se les bloquea la agenda.
model CalendarEventAttendee {
  id             String @id @default(uuid())
  eventId        String
  psychologistId String

  event        CalendarEvent @relation(fields: [eventId], references: [id], onDelete: Cascade)
  psychologist Psychologist  @relation(fields: [psychologistId], references: [id], onDelete: Cascade)

  @@unique([eventId, psychologistId])
  @@index([psychologistId])
  @@map("calendar_event_attendees")
}

model PsychologistAvailability {
  id             String  @id @default(uuid())
  psychologistId String
  dayOfWeek      Int // 1 = lunes ... 7 = domingo
  startTime      String // "HH:mm"
  endTime        String // "HH:mm"
  isActive       Boolean @default(true)

  psychologist Psychologist @relation(fields: [psychologistId], references: [id], onDelete: Cascade)

  @@index([psychologistId])
  @@map("psychologist_availability")
}

model WeeklyReport {
  id                 String   @id @default(uuid())
  psychologistId     String
  weekStartDate      DateTime // lunes de la semana reportada
  submittedAt        DateTime @default(now())
  hoursOfAttention   Int
  activePatientCount Int
  notes              String?
  createdAt          DateTime @default(now())

  psychologist   Psychologist                @relation(fields: [psychologistId], references: [id], onDelete: Cascade)
  patientUpdates WeeklyReportPatientUpdate[]

  @@unique([psychologistId, weekStartDate])
  @@index([psychologistId])
  @@index([weekStartDate])
  @@map("weekly_reports")
}

model WeeklyReportPatientUpdate {
  id               String            @id @default(uuid())
  weeklyReportId   String
  patientId        String
  serviceType      ServiceType
  therapyStatus    TherapyStatus?
  evaluationStatus EvaluationStatus?
  patientType      PatientType?

  weeklyReport WeeklyReport @relation(fields: [weeklyReportId], references: [id], onDelete: Cascade)
  patient      Patient      @relation(fields: [patientId], references: [id])

  @@index([weeklyReportId])
  @@index([patientId])
  @@map("weekly_report_patient_updates")
}

model SiereApplication {
  id             String        @id @default(uuid())
  patientId      String
  psychologistId String
  discountLevel  DiscountLevel
  requestedById  String
  requestedAt    DateTime      @default(now())
  approvedById   String?
  approvedAt     DateTime?
  isActive       Boolean       @default(true)

  patient      Patient      @relation(fields: [patientId], references: [id], onDelete: Cascade)
  psychologist Psychologist @relation(fields: [psychologistId], references: [id])
  requestedBy  User         @relation("SiereRequestedBy", fields: [requestedById], references: [id])
  approvedBy   User?        @relation("SiereApprovedBy", fields: [approvedById], references: [id])

  @@index([patientId])
  @@map("siere_applications")
}

// Respuesta anónima a la encuesta de satisfacción, contestada desde /encuesta
// sin necesidad de sesión. No guarda nada que identifique al paciente: es lo
// que sostiene que las respuestas sean honestas.
//
// `answers` es un mapa { preguntaId: valor } según lib/survey.ts. Se guarda
// como Json a propósito, para poder cambiar el cuestionario sin migrar.
model SurveyResponse {
  id          String   @id @default(uuid())
  submittedAt DateTime @default(now())
  answers     Json

  @@index([submittedAt])
  @@map("survey_responses")
}

model Notification {
  id              String           @id @default(uuid())
  userId          String
  type            NotificationType
  title           String
  message         String
  relatedEntityId String?
  isRead          Boolean          @default(false)
  createdAt       DateTime         @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([isRead])
  @@map("notifications")
}

model AuditLog {
  id            String      @id @default(uuid())
  userId        String
  entityType    String
  entityId      String
  action        AuditAction
  changedFields Json?
  changedAt     DateTime    @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([entityType, entityId])
  @@index([changedAt])
  @@map("audit_log")
}
