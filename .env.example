# PostgreSQL connection string.
# Local:   postgresql://USER:PASSWORD@localhost:5432/cedafam?schema=public
# Neon:    postgresql://USER:PASSWORD@HOST/cedafam?sslmode=require
DATABASE_URL="postgresql://user:password@localhost:5432/cedafam?schema=public"

# NextAuth — generate with: openssl rand -base64 32
NEXTAUTH_SECRET="change-me-in-production"
NEXTAUTH_URL="http://localhost:3000"

# Optional: protects the cron endpoint (Authorization: Bearer <secret>)
CRON_SECRET="change-me-cron-secret"
